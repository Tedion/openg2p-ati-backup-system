# =============================================================================
# OpenG2P backup system: environment configuration
# Copy to /opt/backup/backup.env on the backup host and edit for YOUR environment.
# Every script sources this file; nothing else is environment-specific.
#   cp backup.env.example /opt/backup/backup.env && chmod 640 /opt/backup/backup.env
# Values below are placeholder examples. Replace every one with your own.
# =============================================================================

# --- Backup host (this machine) ---------------------------------------------
BACKUP_ROOT=/opt/backup
BACKUP_USER=backup                       # OS user that owns the repos / runs pg-backup
BACKUP_INSTANCE=mybackup-host             # label used in metrics + alert rules (unique per site)

# --- Source: NFS / filesystem -----------------------------------------------
NFS_SERVER=10.0.0.22
NFS_EXPORT=/srv/nfs/prod
NFS_MOUNT=/mnt/nfs-prod-ro

# --- Source: MinIO / S3 object store ----------------------------------------
MINIO_ENDPOINT=http://10.0.0.31:9000
MINIO_ALIAS=siteminio                     # mc alias name (set with: mc alias set ...)
MINIO_BUCKET=documents

# --- Source: PostgreSQL (pgBackRest) ----------------------------------------
PG_HOST=10.0.0.29
PG_INSTANCE=mybackup-pg                    # label used in WAL alert rules (unique per site)
PG_STANZA=main                            # pgBackRest stanza name
PG_DATA=/var/lib/postgresql/14/main       # only used by the WAL-health helper on the PG host

# --- Source: etcd snapshots --------------------------------------------------
# The cluster's snapshot job ships tarballs into $BACKUP_ROOT/etcd-snapshots ;
# etcd-restic.sh re-packs them into an encrypted restic repo. No vars needed here.

# --- Monitoring (Prometheus Pushgateway) ------------------------------------
PUSHGATEWAY=http://10.0.0.24:32214

# --- Retention (restic) ------------------------------------------------------
RESTIC_KEEP="--keep-daily 7 --keep-weekly 4 --keep-monthly 6"

# --- Notification recipient (SMTP creds live in $BACKUP_ROOT/.smtp) ----------
# see smtp.env.example
