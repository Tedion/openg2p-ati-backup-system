# /etc/pgbackrest/pgbackrest.conf  on the REPO host (= the backup host)
# chown root:<BACKUP_USER>, chmod 640  (contains the cipher pass)
[global]
repo1-path=/opt/backup/pgbackrest
repo1-retention-full=4
repo1-retention-diff=8
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=<GENERATE_AND_STORE_IN_VAULT>
process-max=4
compress-type=zst
compress-level=6
log-level-file=detail
start-fast=y

[main]                                 # <-- stanza name = $PG_STANZA in backup.env
pg1-host=<PG_HOST_IP>
pg1-host-user=postgres
pg1-path=/var/lib/postgresql/14/main   # <-- match your PG version/data dir
