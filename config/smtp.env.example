# Copy to /opt/backup/.smtp on the backup host, fill real values, then:
#   chown root:<BACKUP_USER> /opt/backup/.smtp && chmod 640 /opt/backup/.smtp
# GOTCHA: Gmail app passwords are shown as "xxxx xxxx xxxx xxxx" (with spaces).
#   Strip the spaces and single-quote the value, or sourcing breaks.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@example.org
SMTP_PASS='APP_PASSWORD_NO_SPACES'
SMTP_FROM=alerts@example.org
MAIL_TO=ops-team@example.org
